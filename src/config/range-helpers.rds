namespace "rn.config"

struct.IntPercent {
  percent 'int',
  _features { equality, validation }
}

struct.DoublePercent {
  fraction 'double',
  _features { equality, validation }
}

struct.DoublePercentRange {
  lo 'double',
  hi 'double',
  _features { equality, validation }
}

struct.IntRange {
  min 'int',
  max 'int',
  _features { equality, validation }
}

struct.DoubleRange {
  min 'double',
  max 'double',
  _features { equality, validation }
}

struct.Probability {
  probability 'double',
  _features { equality, validation }
}

struct.NormalDist {
  mean 'double',
  stddev 'double',
  _features { equality, validation }
}

struct.UniformDist {
  min 'double',
  max 'double',
  _features { equality, validation }
}

struct.UniformDistT {
  _template { T },
  min 'T',
  max 'T',
  _features { equality, validation }
}

struct.BoundedNormalDist {
  mean 'double',
  stddev 'double',
  min 'double',
  max 'double',
  _features { equality, validation }
}

struct.Piecewise3Dist {
  min 'double',
  peak 'double',
  max 'double',
  weight_min 'double',
  weight_max 'double',
  _features { equality, validation }
}
