# ss
include "ss/terrain-enums.rds.hpp"

# rand
include "rand/perlin.rds.hpp"

# cartesian
include "gfx/cartesian.hpp"

# refl
include "refl/enum-map.hpp"

# base
include "base/maybe.hpp"

namespace "rn"

enum.e_land_mass {
  small,
  moderate,
  large,
}

enum.e_land_form {
  archipelago,
  normal,
  continents,
}

enum.e_temperature {
  cool,
  temperate,
  warm,
}

enum.e_climate {
  arid,
  normal,
  wet,
}

struct.BiomeAffinity {
  # Ranges from [-3,3] with 0 being "no affinity", meaning that
  # the biomes are left as if randomly placed. More positive num-
  # bers means more clustering around like biomes, while more
  # negative numbers means less clustering than what is random
  # (i.e., repulsion). The OG behavior corresponds to most of
  # these values being just above zero except for Tundra which is
  # closer to 1, as it is more clustered.
  for_self 'double',
  # This ranges from [0,1] and can be interpreted as a proba-
  # bility that the biome will be next to water. For example,
  # swamp/marsh has a larger probability of being near water than
  # other biomes. After the biome is placed (randomly) they will
  # be randomly moved around in a best-effort attempt to make
  # their adjacency to water reflect this value. If this is null
  # then no alteration is done.
  for_water 'base::maybe<double>',
  _features { equality, validation }
}

struct.BiomeClustering {
  affinities 'refl::enum_map<e_biome, BiomeAffinity>',
}

sumtype.BiomeClusteringMode {
  derived {},
  varying {
    values 'BiomeClustering',
  },
}

struct.PerlinLandForm {
  scale 'double',
  fractal 'rng::PerlinFractalOptions',
  _features { equality, validation }
}

struct.PerlinEdgeSuppression {
  enabled 'bool',
  strength 'gfx::dsize',
  _features { equality, validation }
}

# These are technically inputs to the Perlin map generation algo-
# rithm, but they are typically generated randomly since they
# don't really change any macroscopic properties of the map that
# one might want to customize; they just create variations on the
# same map style/type. Thus, together they can be thought of as a
# kind of seed.
struct.PerlinSeed {
  offset_x 'uint32_t',
  offset_y 'uint32_t',
  base     'uint32_t',
  flip     'bool',
}

# Used to hold a parameter representing the temperature and cli-
# mate. In the OG these take on discreet values but we allow a
# spectrum.
#
# For Temperature, this can go from [-200,+200}, and has the fol-
# lowing meaning:
#
#   * -100 ==> "Cool"     in the OG.
#   *    0 ==> "Moderate" in the OG.
#   * +100 ==> "Warm"     in the OG.
#
# Going beyond -100 or +100 makes it even cooler/warmer.

# For Climate, this can go from [-200,+200}, and has the fol-
# lowing meaning:
#
#   * -100 ==> "Arid"   in the OG.
#   *    0 ==> "Normal" in the OG.
#   * +100 ==> "Wet"    in the OG.
#
# Going beyond -100 or +100 makes it even more arid/wet.
struct.WeatherValue {
  value 'int',
  _features { spaceship, validation }
}
