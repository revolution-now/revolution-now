# config
include "range-helpers.rds.hpp"
include "map-gen-types.rds.hpp"

# ss
include "ss/terrain-enums.rds.hpp"

# gfx
include "gfx/cartesian.hpp"

# rand
include "rand/entropy.hpp"

# refl
include "refl/enum-map.hpp"

# base
include "base/maybe.hpp"

namespace "rn.config.map_gen"

struct.LandMass {
  fully_random 'config::Piecewise3Dist',
  customized 'refl::enum_map<e_land_mass, config::BoundedNormalDist>',
  _features { equality, validation }
}

struct.Arctic {
  enabled 'bool',
  min_map_height 'int',
  density 'config::DoublePercent',
}

struct.InlandLakes {
  bias 'config::UniformDist',
  _features { equality, validation }
}

struct.PerlinLandFormRange {
  scale 'config::BoundedNormalDist',
  fractal 'rng::PerlinFractalOptions',
}

struct.LandForm {
  fully_random 'PerlinLandFormRange',
  customized 'refl::enum_map<e_land_form, PerlinLandFormRange>',
  perlin_edge_suppression 'PerlinEdgeSuppression',
  _features { equality, validation }
}

struct.LandLayout {
  land_mass 'LandMass',
  land_form 'LandForm',
  inland_lakes 'InlandLakes',
  arctic 'Arctic',

  remove_crosses 'bool',
}

struct.WeatherDistribution {
  distribution 'config::UniformDistT<WeatherValue>',
}

struct.Temperature {
  fully_random 'WeatherDistribution',
  customized 'refl::enum_map<e_temperature, WeatherValue>',
}

struct.Climate {
  fully_random 'WeatherDistribution',
  customized 'refl::enum_map<e_climate, WeatherValue>',
}

struct.Weather {
  temperature 'Temperature',
  climate 'Climate',
}

struct.BiomeCurveParams {
  weight 'double',
  center 'double',
  stddev 'double',
  sub    'double',
}

struct.BiomeCurve {
  exp    'int',
  params 'BiomeCurveParams',
  _features { equality, validation }
}

struct.Biomes {
  normal_temperature_and_climate [[
    refl::enum_map<e_ground_terrain, BiomeCurve>
  ]],
  temperature_gradient [[
    refl::enum_map<e_ground_terrain, BiomeCurveParams>
  ]],
  climate_gradient [[
    refl::enum_map<e_ground_terrain, BiomeCurveParams>
  ]],
}

struct.Overlay {
  hills_density 'config::DoublePercent',
  mountain_density 'config::DoublePercent',
  hills_range_probability 'config::Probability',
  mountain_range_probability 'config::Probability',
  forest_density 'config::DoublePercent',
}

struct.RiverClimateParameters {
  initiation 'config::Probability',
  start_major 'config::Probability',
  sustain_major 'config::Probability',
  edge_decay 'double',
  _features { equality, validation }
}

struct.RiverLandFormParameters {
  growth 'config::Probability',
}

struct.Rivers {
  # This length includes the water tile which initiates the
  # river.
  min_length 'int',
  turn 'config::Probability',
  fork 'config::Probability',
  fork_is_major 'config::Probability',
  for_land_form 'refl::enum_map<e_land_form, RiverLandFormParameters>',
  for_climate 'refl::enum_map<e_climate, RiverClimateParameters>',
  _features { equality, validation }
}

struct.TerrainGeneration {
  land_layout 'LandLayout',
  weather 'Weather',
  rivers 'Rivers',
  biomes 'Biomes',
  overlay 'Overlay',
}

struct.DwellingGeneration {
  # TODO
}

namespace "rn"

struct.config_map_gen_t {
  default_map_size 'gfx::size',
  terrain_generation 'config::map_gen::TerrainGeneration',
  dwelling_generation 'config::map_gen::DwellingGeneration',

  _features { equality, validation }
}

config.map_gen {}
