set term png size 1920,1200 font "Fira Sans,14"
set output outfile

set title "Clearing/NM Density on Biome by Column (empirical) (bbtm) [2000]"
set key outside right
set grid
set xlabel "X"
set ylabel "Density"
set key autotitle columnhead
set xrange [1:56]
set yrange [0:0.250000]
