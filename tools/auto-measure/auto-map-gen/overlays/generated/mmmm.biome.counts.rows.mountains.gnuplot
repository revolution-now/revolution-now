set term png size 1920,1200 font "Fira Sans,14"
set output outfile

set title "Mountains on Biome by Row (generated) (mmmm) [2000]"
set key outside right
set grid
set xlabel "Y (row)"
set ylabel "Count per Row"
set key autotitle columnhead
set xrange [1:70]
set yrange [0:1.5]
