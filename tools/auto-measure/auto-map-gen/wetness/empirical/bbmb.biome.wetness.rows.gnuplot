set term png size 1920,1200 font "Fira Sans,14"
set output outfile

set title "Wetness on Biome by Row (empirical) (bbmb) [2000]"
set key outside right
set grid
set xlabel "Y"
set ylabel "Density"
set key autotitle columnhead
set xrange [1:70]
set yrange [0:1.0]
