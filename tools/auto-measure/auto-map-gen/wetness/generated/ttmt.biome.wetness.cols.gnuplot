set term png size 1920,1200 font "Fira Sans,14"
set output outfile

set title "Wetness on Biome by Column (generated) (ttmt) [2000]"
set key outside right
set grid
set xlabel "X"
set ylabel "Wetness"
set key autotitle columnhead
set xrange [1:56]
set yrange [0:1.0]
plot for [col=2:*] $CSVData using 1:col with lines lw 3

set output
system sprintf( "eog --fullscreen '%s' >/dev/null 2>&1 &", outfile )
